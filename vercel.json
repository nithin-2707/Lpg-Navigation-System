{
  "version": 2,
  "installCommand": "npm install --include=dev --include=optional",
  "buildCommand": "npm install --prefix frontend @rollup/rollup-linux-x64-gnu --no-save && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}